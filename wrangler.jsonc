{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "atlasguessr",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2026-03-17",
	"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
	"assets": {
		"directory": "dist",
		"binding": "ASSETS"
	}
}
